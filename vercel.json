{
  "rewrites": [
    { "source": "/js/script.js", "destination": "https://plausible.io/js/script.js" },
    { "source": "/api/event", "destination": "https://plausible.io/api/event" }
  ],
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
